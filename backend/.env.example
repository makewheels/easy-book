# Easy-Book 环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# MongoDB 连接字符串
# 本地开发: mongodb://localhost:27017
# 生产环境: mongodb://easy-book:<password>@10.0.20.14:27017/easy_book?authSource=admin
MONGODB_URL=mongodb://localhost:27017

# 数据库名称
DB_NAME=easy_book

# 环境标识 (development / production)
ENVIRONMENT=development
